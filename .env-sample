# Entity counts
NUM_SENSORS=2
NUM_DRONES=0

# MQTT
MQTT_HOST=mqtt-central
MQTT_PORT=1883
MQTT_EXTERNAL_PORT=1884

# Simulation area — SW (bottom-left) corner of the area where entities are placed
SIM_AREA_SW_LAT=40.630
SIM_AREA_SW_LNG=-8.660
SIM_AREA_WIDTH_M=1000
SIM_AREA_HEIGHT_M=1000
SIM_RANDOM_SEED=42

# Base station location (independently configurable from sim area origin)
BASE_STATION_LAT=40.633
BASE_STATION_LNG=-8.662

# Radio ranges
DRONE_RANGE_M=150
BASE_RANGE_M=300

# Simulation timing and movement
TICK_REAL_MS=500
DRONE_SPEED_M_S=5.0

# Map grid
CELL_SIZE_M=50

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
